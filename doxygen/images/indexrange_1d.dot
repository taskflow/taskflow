digraph IndexRange1D {
  rankdir=LR;
  node [shape=circle, style=filled, fillcolor="#AED6F1", fontname="Helvetica", fontsize=12, width=0.6, fixedsize=true];
  edge [penwidth=1.5];

  e0 [label="2"];
  e1 [label="5"];
  e2 [label="8"];
  e3 [label="11"];

  e0 -> e1 [label="  +3  "];
  e1 -> e2 [label="  +3  "];
  e2 -> e3 [label="  +3  "];

  end [shape=plaintext, label="14\n(end)", style="", fillcolor=none];
  e3 -> end [style=dashed, arrowhead=none];
  labelloc=t;
  fontname="Arial";
  fontsize=12;
}
